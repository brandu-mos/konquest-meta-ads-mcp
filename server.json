{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.brandu-mos/konquest-meta-ads-mcp",
  "title": "KonQuest Meta Ads MCP",
  "description": "Supervised Meta Ads operating system for Claude Code with 57 campaign management tools.",
  "repository": {
    "url": "https://github.com/brandu-mos/konquest-meta-ads-mcp",
    "source": "github"
  },
  "version": "2.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "konquest-meta-ads-mcp",
      "version": "2.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Meta Marketing API access token",
